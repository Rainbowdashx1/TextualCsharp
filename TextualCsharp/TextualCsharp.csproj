<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <PackageId>TextualCsharp</PackageId>
    <Version>1.2.0</Version>
    <Authors>Rainbowdashx1</Authors>
    <Description>A Textual-inspired TUI library for C#.</Description>
    <PackageLicense>MIT</PackageLicense>
    <RepositoryUrl>https://github.com/Rainbowdashx1/TextualCsharp</RepositoryUrl>
    <PackageTags>tui;terminal;textual;console</PackageTags>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

</Project>
